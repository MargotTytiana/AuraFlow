
{
 
  "name":        "auraflow",
  "version":     "0.1.0",
  "description": "Gesture-controlled ambient soundscape for meditation, focus, and sleep.",
  "license":     "MIT",

  "private": true,

  "scripts": {

    "dev": "vite",


    "build": "tsc --noEmit && vite build",

    "typecheck": "tsc --noEmit",

    "preview": "vite preview",

    "test": "jest --passWithNoTests",


    "test:watch": "jest --watch",

    "lint": "eslint src --ext .ts && stylelint src/**/*.css",

    "lint:fix": "eslint src --ext .ts --fix && stylelint src/**/*.css --fix"
  },

  "dependencies": {
    "@mediapipe/camera_utils": "^0.3.1675466862",
    "@mediapipe/hands":        "^0.4.1675469240"
  },

  "devDependencies": {

    "typescript": "^5.4.0",

    "vite": "^5.2.0",

    "vite-plugin-pwa": "^0.19.0",

 
    "jest":                  "^29.7.0",
    "ts-jest":               "^29.1.0",
    "@types/jest":           "^29.5.0",
    "jest-environment-jsdom": "^29.7.0",

    "eslint":                            "^8.57.0",
    "@typescript-eslint/parser":         "^7.0.0",
    "@typescript-eslint/eslint-plugin":  "^7.0.0",

    "stylelint":                 "^16.0.0",
    "stylelint-config-standard": "^36.0.0",


    "@types/node": "^20.0.0"
  },


  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=9.0.0"
  },


  "jest": {

    "preset": "ts-jest",

    "testEnvironment": "jsdom",

    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },

    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/types/**",
      "!src/main.ts",
      "!src/App.ts"
    ]
  }
}